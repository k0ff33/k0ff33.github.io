---
interface Props {
	slug: string;
	title: string;
	tags?: string[];
	description?: string;
	date: string | Date;
}

const { slug, title, tags = [], description, date } = Astro.props;
const postDate = new Date(date);
---

<li class="post">
  <a href={`/blog/${slug}/`} class="title">{title}</a>
  <time datetime={postDate.toISOString()}>
    {
      postDate.toLocaleDateString("en-us", {
        year: "numeric",
        month: "short",
        day: "numeric",
      })
    }
  </time>
  <br />
  {description && <span class="excerpt">{description}</span>}
  <div>
    {
      tags.map((tag) => (
        <a class="tag" href={`/tag/${tag}`}>
          #{tag}
        </a>
      ))
    }
  </div>
</li>
